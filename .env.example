# Port the HTTP server listens on.
PORT=4000

# Public URL of the deployed app. Used to build QR code targets.
# Local dev:  http://localhost:4000
# LAN dev:    http://<your-mac-lan-ip>:4000   (so phones on the same wifi can scan)
# Production: https://your-domain.example
BASE_URL=http://localhost:4000

# 32+ random characters. Generate with:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
SESSION_SECRET=change-me-to-a-long-random-string

# Postgres connection string.
# Local (docker compose up -d):   postgres://vending:vending@localhost:5432/vending
# Render/Railway/Fly:             provided automatically via DATABASE_URL
# Neon/Supabase free tier:        paste the connection string from their dashboard
DATABASE_URL=postgres://vending:vending@localhost:5432/vending

# Set to "production" when deploying.
NODE_ENV=development

# --- Email (for signup verification) ---
# If RESEND_API_KEY is blank, the app prints verification links to the server
# terminal instead of sending real email. Perfect for local dev.
# Get a key: https://resend.com → Sign up → API Keys
RESEND_API_KEY=
# On the free tier without a verified domain, Resend only accepts
#   "Your Name <onboarding@resend.dev>"
# and can only deliver to the email your Resend account is registered with.
# Once you verify a domain, change this to noreply@yourdomain.example.
EMAIL_FROM=Vending Request <onboarding@resend.dev>
