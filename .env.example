# Port the HTTP server listens on.
PORT=4000

# 32+ random characters. Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
SESSION_SECRET=change-me-to-a-long-random-string

# Public URL of the deployed app. Used to build QR code targets.
# In dev: http://localhost:4000
# In prod: https://your-domain.example
BASE_URL=http://localhost:4000

# Set to "production" when deploying.
NODE_ENV=development
