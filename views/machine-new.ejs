<%- include('_header') %>

<div class="auth">
  <h1>Add a machine</h1>
  <p class="muted">You can always edit this later.</p>

  <% if (error) { %><div class="alert"><%= error %></div><% } %>

  <form action="/machines" method="post" class="stack">
    <input type="hidden" name="_csrf" value="<%= csrfToken %>">

    <label>Name
      <input type="text" name="name" required maxlength="80"
             value="<%= form.name || '' %>" autofocus
             placeholder="Lobby Vending">
    </label>

    <label>Location <span class="muted">(optional)</span>
      <input type="text" name="location" maxlength="160"
             value="<%= form.location || '' %>"
             placeholder="Building A, 1st floor break room">
    </label>

    <button type="submit" class="btn btn-dark btn-lg btn-block">Create machine</button>
  </form>
  <p class="muted center"><a href="/dashboard">← Back to dashboard</a></p>
</div>

<%- include('_footer') %>
