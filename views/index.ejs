<%- include('_header') %>

<section class="hero">
  <h1>Let customers tell you what to stock.</h1>
  <p class="lede">
    Stick a QR code on your vending machine. Customers scan, type the product
    they want, submit their number. You get a clean dashboard of requests per machine.
  </p>
  <div class="cta">
    <% if (currentUser) { %>
      <a class="btn btn-dark btn-lg" href="/dashboard">Open dashboard</a>
    <% } else { %>
      <a class="btn btn-dark btn-lg" href="/signup">Get started</a>
      <a class="btn btn-ghost btn-lg" href="/login">Log in</a>
    <% } %>
  </div>
</section>

<section class="steps">
  <div class="step">
    <span class="step-num">01</span>
    <h3>Add a machine</h3>
    <p>Name it, note its location. It gets its own private link + QR code.</p>
  </div>
  <div class="step">
    <span class="step-num">02</span>
    <h3>Print the sticker</h3>
    <p>One-click printable poster. Tape it by the selection buttons.</p>
  </div>
  <div class="step">
    <span class="step-num">03</span>
    <h3>Watch requests arrive</h3>
    <p>Customers scan, submit a product + their number. You see it live.</p>
  </div>
</section>

<%- include('_footer') %>
