<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <meta name="color-scheme" content="light">
  <title>Request a product</title>
  <link rel="stylesheet" href="/styles.css">
  <link rel="icon" href="/favicon.svg" type="image/svg+xml">
  <script src="/app.js" defer></script>
</head>
<body class="public">
  <main class="public-main">
    <header class="public-head">
      <h1>What should we stock?</h1>
      <p class="muted"><%= machine.name %><% if (machine.location) { %> · <%= machine.location %><% } %></p>
    </header>

    <% if (error) { %><div class="alert"><%= error %></div><% } %>

    <form action="/r/<%= machine.public_token %>" method="post" class="public-form">
      <label class="big-field">
        <span class="label">Product</span>
        <input type="text" name="product_name" required maxlength="120"
               value="<%= form.product_name || '' %>" autofocus
               autocomplete="off"
               placeholder="e.g. Flamin' Hot Cheetos">
      </label>

      <label class="big-field">
        <span class="label">Your phone</span>
        <input type="tel" name="phone" required maxlength="40"
               value="<%= form.phone || '' %>"
               inputmode="tel"
               autocomplete="tel"
               placeholder="555-123-4567">
      </label>

      <!-- honeypot: real users leave blank -->
      <div class="hp" aria-hidden="true">
        <label>Website<input type="text" name="website" tabindex="-1" autocomplete="off"></label>
      </div>

      <button type="submit" class="btn btn-dark btn-xl btn-block">Submit</button>
      <p class="muted tiny center">No account needed. Your number is only shared with the operator.</p>
    </form>
  </main>
</body>
</html>
