<%- include('_header') %>

<div class="page-head">
  <div>
    <p class="muted small"><a href="/dashboard">← Dashboard</a></p>
    <h1><%= machine.name %></h1>
    <% if (machine.location) { %>
      <p class="muted"><%= machine.location %></p>
    <% } %>
  </div>
</div>

<div class="twocol">
  <aside class="qr-panel">
    <img class="qr" src="/machines/<%= machine.id %>/qr.png" alt="QR code">
    <p class="muted small center">Customers scan this to submit requests.</p>
    <div class="url-block">
      <p class="muted tiny">PUBLIC URL</p>
      <code><%= publicUrl %></code>
    </div>
    <div class="actions">
      <a class="btn btn-dark btn-block" href="/machines/<%= machine.id %>/qr/print" target="_blank">Print poster</a>
      <a class="btn btn-ghost btn-block" href="/machines/<%= machine.id %>/qr.png" download="machine-<%= machine.id %>-qr.png">Download PNG</a>
    </div>

    <details class="danger-zone">
      <summary>Delete machine</summary>
      <p class="muted tiny">Removes the QR link and all requests. Permanent.</p>
      <form action="/machines/<%= machine.id %>/delete" method="post"
            data-confirm="Delete this machine and all its requests? This cannot be undone.">
        <input type="hidden" name="_csrf" value="<%= csrfToken %>">
        <button type="submit" class="btn btn-danger btn-sm btn-block">Delete</button>
      </form>
    </details>
  </aside>

  <section class="requests">
    <nav class="tabs">
      <a class="<%= status === 'new' ? 'active' : '' %>" href="?status=new">New</a>
      <a class="<%= status === 'addressed' ? 'active' : '' %>" href="?status=addressed">Addressed</a>
      <a class="<%= status === 'dismissed' ? 'active' : '' %>" href="?status=dismissed">Dismissed</a>
    </nav>

    <% if (requests.length === 0) { %>
      <div class="empty mini">
        <p class="muted">No <%= status %> requests.</p>
      </div>
    <% } else { %>
      <ul class="req-list">
        <% requests.forEach((r) => { %>
          <li class="req">
            <div class="req-main">
              <h3><%= r.product_name %></h3>
              <p class="req-meta">
                <a href="tel:<%= r.phone.replace(/[^0-9+]/g, '') %>" class="phone"><%= r.phone %></a>
                <span class="sep">·</span>
                <time class="muted small" datetime="<%= r.created_at.toISOString ? r.created_at.toISOString() : r.created_at %>"><%= r.created_at.toLocaleString ? r.created_at.toLocaleString() : r.created_at %></time>
              </p>
            </div>
            <div class="req-actions">
              <% if (status !== 'addressed') { %>
                <form action="/requests/<%= r.id %>/status" method="post" class="inline-form">
                  <input type="hidden" name="_csrf" value="<%= csrfToken %>">
                  <input type="hidden" name="status" value="addressed">
                  <button class="btn btn-sm btn-dark" type="submit">Addressed</button>
                </form>
              <% } %>
              <% if (status !== 'dismissed') { %>
                <form action="/requests/<%= r.id %>/status" method="post" class="inline-form">
                  <input type="hidden" name="_csrf" value="<%= csrfToken %>">
                  <input type="hidden" name="status" value="dismissed">
                  <button class="btn btn-sm btn-ghost" type="submit">Dismiss</button>
                </form>
              <% } %>
              <% if (status !== 'new') { %>
                <form action="/requests/<%= r.id %>/status" method="post" class="inline-form">
                  <input type="hidden" name="_csrf" value="<%= csrfToken %>">
                  <input type="hidden" name="status" value="new">
                  <button class="btn btn-sm btn-ghost" type="submit">Reopen</button>
                </form>
              <% } %>
            </div>
          </li>
        <% }) %>
      </ul>
    <% } %>
  </section>
</div>

<%- include('_footer') %>
