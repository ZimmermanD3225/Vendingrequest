<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <meta name="color-scheme" content="light dark">
  <title><%= title %> — Vending Request</title>
  <script src="/theme-init.js"></script>
  <link rel="stylesheet" href="/styles.css">
  <link rel="icon" href="/favicon.svg" type="image/svg+xml">
  <script src="/app.js" defer></script>
</head>
<body>
  <header class="topbar">
    <a class="brand" href="/">
      <span class="brand-mark"></span>
      <span class="brand-text">Vending Request</span>
    </a>
    <nav class="topnav">
      <% if (currentUser) { %>
        <a href="/dashboard" class="topnav-link">Dashboard</a>
        <a href="/reorder" class="topnav-link">Reorder</a>
        <div class="user-menu">
          <button type="button" class="topnav-link user-menu-toggle" id="user-menu-toggle"
                  aria-expanded="false" aria-haspopup="true">
            <svg width="16" height="16" viewBox="0 0 20 20" fill="none" stroke="currentColor"
                 stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
              <circle cx="10" cy="6" r="3.5"/>
              <path d="M3 18c0-3.5 3-5.5 7-5.5s7 2 7 5.5"/>
            </svg>
            <span class="user-menu-name"><%= currentUser.businessName || currentUser.username %></span>
            <svg class="user-menu-caret" width="10" height="10" viewBox="0 0 20 20" fill="none" stroke="currentColor"
                 stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
              <path d="M5 8l5 5 5-5"/>
            </svg>
          </button>
          <div class="user-menu-dropdown" id="user-menu-dropdown">
            <a href="/settings" class="user-menu-item">
              <svg width="15" height="15" viewBox="0 0 20 20" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><circle cx="10" cy="10" r="2.5"/><path d="M16.3 12.5a1.4 1.4 0 00.3 1.5l.05.05a1.7 1.7 0 11-2.4 2.4l-.05-.05a1.4 1.4 0 00-1.5-.3 1.4 1.4 0 00-.85 1.3v.15a1.7 1.7 0 11-3.4 0v-.08A1.4 1.4 0 007.6 16a1.4 1.4 0 00-1.5.3l-.05.05a1.7 1.7 0 11-2.4-2.4l.05-.05a1.4 1.4 0 00.3-1.5 1.4 1.4 0 00-1.3-.85H2.5a1.7 1.7 0 010-3.4h.08A1.4 1.4 0 004 7.6a1.4 1.4 0 00-.3-1.5l-.05-.05a1.7 1.7 0 112.4-2.4l.05.05a1.4 1.4 0 001.5.3h.07a1.4 1.4 0 00.85-1.3V2.5a1.7 1.7 0 013.4 0v.08a1.4 1.4 0 00.85 1.3 1.4 1.4 0 001.5-.3l.05-.05a1.7 1.7 0 112.4 2.4l-.05.05a1.4 1.4 0 00-.3 1.5v.07a1.4 1.4 0 001.3.85h.15a1.7 1.7 0 010 3.4h-.08a1.4 1.4 0 00-1.3.85z"/></svg>
              Settings
            </a>
            <form action="/logout" method="post" class="user-menu-form">
              <input type="hidden" name="_csrf" value="<%= csrfToken %>">
              <button type="submit" class="user-menu-item user-menu-logout">
                <svg width="15" height="15" viewBox="0 0 20 20" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M7 17H4a1 1 0 01-1-1V4a1 1 0 011-1h3M13 14l4-4-4-4M17 10H7"/></svg>
                Log out
              </button>
            </form>
          </div>
        </div>
      <% } else { %>
        <a href="/login" class="topnav-link">Log in</a>
        <a href="/signup" class="btn btn-dark btn-sm topnav-cta">Sign up</a>
      <% } %>
      <button type="button" class="theme-toggle" id="theme-toggle"
              aria-label="Toggle color theme" title="Toggle theme">
        <svg class="icon-moon" viewBox="0 0 20 20" fill="none" stroke="currentColor"
             stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <path d="M16 11.5A6.5 6.5 0 018.5 4a6.5 6.5 0 107.5 7.5z"/>
        </svg>
        <svg class="icon-sun" viewBox="0 0 20 20" fill="none" stroke="currentColor"
             stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <circle cx="10" cy="10" r="3.5"/>
          <path d="M10 2v2M10 16v2M2 10h2M16 10h2M4.3 4.3l1.4 1.4M14.3 14.3l1.4 1.4M4.3 15.7l1.4-1.4M14.3 5.7l1.4-1.4"/>
        </svg>
      </button>
    </nav>
  </header>
  <% if (flash) { %>
    <div class="toast toast-<%= flash.type %>" role="status" aria-live="polite">
      <span class="toast-icon">
        <% if (flash.type === 'success') { %>
          <svg width="16" height="16" viewBox="0 0 20 20" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M5 10.5l3 3 7-7"/></svg>
        <% } else if (flash.type === 'error') { %>
          <svg width="16" height="16" viewBox="0 0 20 20" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M5 5l10 10M15 5L5 15"/></svg>
        <% } %>
      </span>
      <span><%= flash.message %></span>
    </div>
  <% } %>
  <main class="main">
