<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <meta name="color-scheme" content="light">
  <title><%= title %> — Vending Request</title>
  <link rel="stylesheet" href="/styles.css">
  <link rel="icon" href="/favicon.svg" type="image/svg+xml">
  <script src="/app.js" defer></script>
</head>
<body>
  <header class="topbar">
    <a class="brand" href="/">
      <span class="brand-mark"></span>
      <span class="brand-text">Vending Request</span>
    </a>
    <nav class="topnav">
      <% if (currentUser) { %>
        <span class="biz muted"><%= currentUser.businessName || currentUser.username %></span>
        <a href="/dashboard">Dashboard</a>
        <form action="/logout" method="post" class="inline-form">
          <input type="hidden" name="_csrf" value="<%= csrfToken %>">
          <button type="submit" class="link-button">Log out</button>
        </form>
      <% } else { %>
        <a href="/login">Log in</a>
        <a href="/signup" class="btn btn-dark btn-sm">Sign up</a>
      <% } %>
    </nav>
  </header>
  <% if (flash) { %>
    <div class="toast toast-<%= flash.type %>" role="status" aria-live="polite">
      <span class="toast-icon">
        <% if (flash.type === 'success') { %>
          <svg width="16" height="16" viewBox="0 0 20 20" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M5 10.5l3 3 7-7"/></svg>
        <% } else if (flash.type === 'error') { %>
          <svg width="16" height="16" viewBox="0 0 20 20" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M5 5l10 10M15 5L5 15"/></svg>
        <% } %>
      </span>
      <span><%= flash.message %></span>
    </div>
  <% } %>
  <main class="main">
