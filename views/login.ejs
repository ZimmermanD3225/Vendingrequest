<%- include('_header') %>

<div class="auth">
  <h1>Log in</h1>

  <% if (error) { %><div class="alert"><%= error %></div><% } %>

  <form action="/login" method="post" class="stack">
    <input type="hidden" name="_csrf" value="<%= csrfToken %>">

    <label>Username
      <input type="text" name="username" required value="<%= form.username || '' %>"
             autofocus autocomplete="username">
    </label>

    <label>Password
      <input type="password" name="password" required autocomplete="current-password">
    </label>
    <p class="muted small" style="margin-top:-4px;text-align:right;">
      <a href="/forgot-password">Forgot password?</a>
    </p>

    <button type="submit" class="btn btn-dark btn-lg btn-block">Log in</button>
  </form>
  <p class="muted center">New here? <a href="/signup">Create an account</a>.</p>
</div>

<%- include('_footer') %>
