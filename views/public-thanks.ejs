<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <meta name="color-scheme" content="light">
  <title>Thanks!</title>
  <link rel="stylesheet" href="/styles.css">
  <link rel="icon" href="/favicon.svg" type="image/svg+xml">
  <script src="/app.js" defer></script>
</head>
<body class="public">
  <main class="public-main">
    <div class="thanks">
      <div class="check-wrap" aria-hidden="true">
        <svg class="check-svg" viewBox="0 0 52 52">
          <path d="M14 27 l8 8 l16 -18" />
        </svg>
      </div>
      <h1>Got it</h1>
      <p class="muted">The operator of <strong><%= machine.name %></strong> will see your <%= type === 'issue' ? 'report' : 'request' %>.</p>
      <a class="btn btn-ghost" href="/r/<%= machine.public_token %>">Submit another</a>
    </div>
  </main>
</body>
</html>
