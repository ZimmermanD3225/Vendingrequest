<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <title>Print — <%= machine.name %></title>
  <link rel="stylesheet" href="/styles.css">
  <script src="/app.js" defer></script>
</head>
<body class="print">
  <div class="poster">
    <p class="poster-top">Request a snack or drink</p>
    <h1 class="poster-title">Scan to tell us what to stock</h1>
    <img class="poster-qr" src="/machines/<%= machine.id %>/qr.png" alt="Request QR code">
    <p class="poster-machine"><%= machine.name %></p>
    <% if (machine.location) { %>
      <p class="poster-location"><%= machine.location %></p>
    <% } %>
    <p class="poster-url"><%= publicUrl %></p>
  </div>
  <div class="print-controls">
    <button id="print-btn" class="btn btn-dark btn-lg">Print this page</button>
    <a href="/machines/<%= machine.id %>" class="btn btn-ghost">← Back</a>
  </div>
</body>
</html>
