<%- include('_header') %>

<div class="auth">
  <h1>Create an account</h1>
  <p class="muted">Takes 30 seconds. No card required.</p>

  <% if (error) { %><div class="alert"><%= error %></div><% } %>

  <form action="/signup" method="post" class="stack">
    <input type="hidden" name="_csrf" value="<%= csrfToken %>">

    <label>Username
      <input type="text" name="username" required minlength="3" maxlength="32"
             value="<%= form.username || '' %>" autofocus autocomplete="username">
    </label>

    <label>Password
      <input type="password" name="password" required minlength="8" autocomplete="new-password">
      <small>8+ characters.</small>
    </label>

    <label>Email
      <input type="email" name="email" required maxlength="160"
             value="<%= form.email || '' %>" autocomplete="email">
      <small>We'll send a verification link — your account isn't active until you click it.</small>
    </label>

    <label>Business name <span class="muted">(optional)</span>
      <input type="text" name="business_name" maxlength="120"
             value="<%= form.business_name || '' %>">
    </label>

    <button type="submit" class="btn btn-dark btn-lg btn-block">Create account</button>
  </form>
  <p class="muted center">Have one? <a href="/login">Log in</a>.</p>
</div>

<%- include('_footer') %>
