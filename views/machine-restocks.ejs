<%- include('_header') %>

<div class="page-head">
  <div>
    <p class="muted small"><a href="/machines/<%= machine.id %>">← <%= machine.name %></a></p>
    <h1>Log restock</h1>
    <p class="muted">Record what you loaded into this machine.</p>
  </div>
</div>

<div class="restock-layout">
  <section class="restock-form-card">
    <% if (error) { %><div class="alert"><%= error %></div><% } %>

    <form action="/machines/<%= machine.id %>/restocks" method="post" id="restock-form">
      <input type="hidden" name="_csrf" value="<%= csrfToken %>">

      <div id="restock-items">
        <div class="restock-row">
          <input type="text" name="item_name" class="restock-input-name" placeholder="Product name" required autocomplete="off">
          <input type="number" name="item_qty" class="restock-input-qty" placeholder="Qty" min="1" required>
          <button type="button" class="restock-remove" style="display:none;" aria-label="Remove">&times;</button>
        </div>
      </div>

      <button type="button" class="btn btn-ghost btn-sm" id="add-restock-row" style="margin-top:4px;">+ Add another item</button>

      <div class="restock-notes">
        <label class="muted small">Notes <span class="muted">(optional)</span></label>
        <textarea name="notes" rows="2" maxlength="500" placeholder="Any notes about this visit..."></textarea>
      </div>

      <button type="submit" class="btn btn-dark btn-lg btn-block" style="margin-top:16px;">Save restock</button>
    </form>
  </section>

  <section class="restock-history-card">
    <h2>Restock history</h2>
    <% if (restocks.length === 0) { %>
      <p class="muted" style="padding:24px 0;text-align:center;">No restocks logged yet. Log your first one above.</p>
    <% } else { %>
      <div class="restock-history-list">
        <% restocks.forEach((r) => { %>
          <div class="restock-entry">
            <div class="restock-entry-items">
              <% const items = Array.isArray(r.items) ? r.items : JSON.parse(r.items || '[]'); %>
              <% items.forEach((i) => { %>
                <span class="restock-chip"><strong><%= i.qty %>x</strong> <%= i.name %></span>
              <% }) %>
            </div>
            <div class="restock-entry-meta">
              <time class="muted small"><%= new Date(r.created_at).toLocaleString() %></time>
              <% if (r.notes) { %><span class="muted small"> — <%= r.notes %></span><% } %>
            </div>
          </div>
        <% }) %>
      </div>
    <% } %>
  </section>
</div>

<%- include('_footer') %>
