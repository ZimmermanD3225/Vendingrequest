<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <title><%= title %> — Vending Request</title>
  <link rel="stylesheet" href="/styles.css">
</head>
<body>
  <main class="container narrow">
    <div class="card">
      <h1><%= title %></h1>
      <p><%= message %></p>
      <% if (stack) { %>
        <pre class="stack"><%= stack %></pre>
      <% } %>
      <p><a class="btn btn-ghost" href="/">Go home</a></p>
    </div>
  </main>
</body>
</html>
