<%- include('_header') %>

<div class="page-head">
  <div>
    <h1>Machines</h1>
    <p class="muted"><%= machines.length %> total</p>
  </div>
  <a class="btn btn-dark" href="/machines/new">+ New machine</a>
</div>

<% if (machines.length === 0) { %>
  <div class="empty">
    <h2>No machines yet</h2>
    <p class="muted">Add your first machine to get its QR code.</p>
    <a class="btn btn-dark" href="/machines/new">Add a machine</a>
  </div>
<% } else { %>
  <div class="machines">
    <% machines.forEach((m) => { %>
      <a class="mcard" href="/machines/<%= m.id %>">
        <div class="mcard-head">
          <div>
            <h3><%= m.name %></h3>
            <% if (m.location) { %><p class="muted small"><%= m.location %></p><% } %>
          </div>
          <% if (m.new_count > 0) { %>
            <span class="pill pill-dot"><%= m.new_count %> new</span>
          <% } else { %>
            <span class="pill muted">0 new</span>
          <% } %>
        </div>

        <% if (m.recent && m.recent.length > 0) { %>
          <ul class="mcard-recent">
            <% m.recent.forEach((r) => { %>
              <li>
                <span class="req-product"><%= r.product_name %></span>
                <span class="muted small"><%= r.phone %></span>
              </li>
            <% }) %>
          </ul>
        <% } else { %>
          <p class="muted small mcard-empty">No new requests.</p>
        <% } %>

        <div class="mcard-foot muted small">
          <%= m.total_count %> total request<%= m.total_count === 1 ? '' : 's' %> · View →
        </div>
      </a>
    <% }) %>
  </div>
<% } %>

<%- include('_footer') %>
