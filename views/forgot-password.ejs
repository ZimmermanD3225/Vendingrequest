<%- include('_header') %>

<div class="auth">
  <h1>Forgot password</h1>
  <p class="muted">Enter your email and we'll send a reset link.</p>

  <% if (error) { %><div class="alert"><%= error %></div><% } %>

  <form action="/forgot-password" method="post" class="stack">
    <input type="hidden" name="_csrf" value="<%= csrfToken %>">

    <label>Email address
      <input type="email" name="email" required autofocus autocomplete="email">
    </label>

    <button type="submit" class="btn btn-dark btn-lg btn-block">Send reset link</button>
  </form>
  <p class="muted center"><a href="/login">Back to log in</a></p>
</div>

<%- include('_footer') %>
